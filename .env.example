## Database
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/zlati_pediatrics?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/zlati_pediatrics"

## Auth (REQUIRED in production — generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-secret-min-32-chars"

## OAuth Providers (optional — only configure providers you use)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

## PII Encryption (REQUIRED in production — must be exactly 32+ characters)
## Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY="replace-with-a-32-plus-char-random-secret"

## Email
RESEND_API_KEY=""

## AI (optional)
OPENAI_API_KEY=""
OPENAI_SUMMARY_MODEL="gpt-4o"
OPENAI_TRANSCRIPTION_MODEL="whisper-1"

## Vercel AI Gateway (optional — alternative to direct OpenAI)
VERCEL_AI_GATEWAY_API_KEY=""
VERCEL_AI_GATEWAY_BASE_URL="https://ai-gateway.vercel.sh/v1"
VERCEL_AI_GATEWAY_MODEL="openai/gpt-5.4"

## Redis rate limiting — Upstash (optional but recommended for production)
## Create a free database at https://console.upstash.com and copy REST credentials
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

## Internal cron authentication (generate with: openssl rand -hex 16)
CRON_SECRET="replace-with-a-random-cron-secret"

## Deployment
VERCEL_URL="localhost:3000"

## Docker / local dev database (used by docker-compose)
## Generate with: openssl rand -hex 16
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="replace-with-strong-password"

## Observability (docker-compose only)
## Generate with: openssl rand -hex 16
ELASTIC_PASSWORD="replace-with-strong-password"
GRAFANA_ADMIN_PASSWORD="replace-with-strong-password"
